<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Login</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<link rel="stylesheet" href="/public/static/css/login.css">

</head>

<body>

<div class="login-wrapper">

    <div class="login-card">

        <div class="text-center mb-4">
            <h3 class="fw-bold">Welcome {{ .title }} </h3>
            <p class="text-muted">Please sign in</p>
        </div>

        <div id="alertBox" class="alert alert-danger d-none"></div>

        <form id="loginForm">

            <div class="mb-3">
                <label class="form-label">Username</label>
                <input type="text"
                       class="form-control"
                       name="username"
                       placeholder="Enter username"
                       required>
            </div>

            <div class="mb-4">
                <label class="form-label">Password</label>
                <input type="password"
                       class="form-control"
                       name="password"
                       placeholder="Enter password"
                       required>
            </div>

            <button type="submit" class="btn btn-primary w-100" id="loginBtn">
                Sign In
            </button>

        </form>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>

<script src="/public/static/js/login.js"></script>

</body>
</html>